# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# This file configures the LOCAL Docker Compose stack only.
# It is NOT used in AWS — in production these values come from Terraform,
# Kubernetes Secrets, and AWS Secrets Manager (that's your job to build).
#
# Setup:
#   1. Edit customization.json with YOUR details.
#   2. Run:  make customize     (renders .env from this file + templates)
#   3. Run:  make dev
#
# You normally do NOT need to edit this file by hand.
# =============================================================================

# ---- PostgreSQL (local container) ----
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_local_password
POSTGRES_DB=portfolio
POSTGRES_PORT=5432

# Connection string the backend uses to reach the local postgres container.
DATABASE_URL=postgresql://portfolio:portfolio_local_password@postgres:5432/portfolio

# ---- Backend API (local container) ----
BACKEND_PORT=4000

# ---- Frontend (local Vite dev server / nginx) ----
FRONTEND_PORT=3000
# Where the frontend looks for the backend API in the browser.
VITE_API_BASE_URL=http://localhost:4000

# ---- Project identity (mirrored from customization.json) ----
# Rendered automatically by `make customize`. Do not edit here.
PROJECT_NAME=__PROJECT_NAME__
AWS_REGION=__AWS_REGION__
