# ---- Local environment ----
.env
*.local

# ---- Node / frontend / backend ----
node_modules/
dist/
build/
.vite/
coverage/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Lambdas ----
lambdas/**/node_modules/
lambdas/**/*.zip

# ---- Terraform ----
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
*.tfvars            # generated by `make customize` from terraform.tfvars.template
!*.tfvars.example   # but keep any committed example files

# ---- Kubernetes / kustomize render output ----
kubernetes/**/rendered.yaml

# ---- Generated by scripts/apply-customization ----
# Files rendered from *.template are committed by students intentionally,
# so they are NOT ignored. The generated .env IS ignored (see above).

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
